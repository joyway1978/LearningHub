[run]
source = app
omit =
    */tests/*
    */test_*
    */venv/*
    */env/*
    */__pycache__/*
    */migrations/*
    */alembic/*
    app/core/storage.py
    app/services/thumbnail_service.py
    app/core/tasks.py
    app/main.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if settings.debug:
    if settings.environment == "development":
    except Exception as e:
    logger.debug
    logger.info
    logger.warning
    logger.error

[html]
directory = htmlcov